# Jarvis 2.0 Environment Configuration Template
# Copy this file to .env and fill in your API keys

# Core LLMs
# Enables the primary assistant logic (Get it from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback LLM provider for uncensored or diverse models (Get it from: https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Used for fast, open-source technical models (Get it from: https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Ultra-fast fallback provider (Get it from: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Image Generation Models
# Enables /imagine command for high quality images (Get it from: https://platform.stability.ai/account/keys)
STABILITY_API_KEY=your_stability_api_key_here

# Fast, serverless AI models (Get it from: https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACOUNT_ID=your_cloudflare_account_id_here

# Free, no-auth image generation fallback (No API key needed usually, but space reserved)
POLLINATION_API_KEY=your_pollinations_api_key_here

# Automations
# Enables news reading capabilities (Get it from: https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# Enables weather forecasting (Get it from: https://openweathermap.org/api)
WEATHER_API_KEY=your_weather_api_key_here

# Enables YouTube video search and playback (Get it from: Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Enables web search automations (Get it from: https://serpapi.com/)
SERPAPI_API_KEY=your_serpapi_api_key_here
