# Jarvis 2.0 Environment Configuration Template
# Copy this file to .env and fill in your API keys

# YouTube Data API v3 Key (for search and playback)
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenWeatherMap API Key (for weather updates)
OPENWEATHER_API_KEY=your_weather_api_key_here

# Hugging Face Inference API Token
HF_TOKEN=your_huggingface_token_here

# OpenRouter API Key (for LLM services)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Stability AI API Key (for image generation fallback)
STABILITY_API_KEY=your_stability_api_key_here

# Groq API Key (for fast LLM responses)
GROQ_API_KEY=your_groq_api_key_here

# SerpAPI Key (for advanced web searching)
SERPAPI_API_KEY=your_serpapi_api_key_here

# News API Key (for daily news updates)
NEWS_API_KEY=your_news_api_key_here

# Decohere AI JWT Token (for specialized AI features)
DECOHERE_JWT_TOKEN=your_decohere_token_here
